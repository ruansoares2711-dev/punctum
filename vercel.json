{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/server",
  "installCommand": "bun install",
  "framework": "tanstack-start",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.js"
    }
  ]
}