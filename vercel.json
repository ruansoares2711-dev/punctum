{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "installCommand": "bun install",
  "framework": "tanstack-start",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(?!assets/)(.*)$",
      "dest": "/api/index.js"
    }
  ]
}